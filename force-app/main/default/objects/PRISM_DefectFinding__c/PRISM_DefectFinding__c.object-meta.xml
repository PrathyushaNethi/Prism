<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowInChatterGroups>true</allowInChatterGroups>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>A defect or finding recorded during an Inspection. Drives work order creation and wildfire risk scoring.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>

    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Defect Finding</label>
    <nameField>
        <label>Defect ID</label>
        <type>AutoNumber</type>
        <displayFormat>DEF-{00000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
    <pluralLabel>Defect Findings</pluralLabel>
    <sharingModel>ControlledByParent</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
